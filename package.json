{
  "name": "compaction-orchestrator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @anshulluhsna/compaction-orchestrator && npm run build -w @compaction-orchestrator/api",
    "dev": "npm run build -w @anshulluhsna/compaction-orchestrator && npm run dev -w @compaction-orchestrator/api",
    "dev:web": "npm run dev -w @compaction-orchestrator/web",
    "build:web": "npm run build -w @compaction-orchestrator/web",
    "start": "npm run start -w @compaction-orchestrator/api",
    "typecheck": "npm run build -w @anshulluhsna/compaction-orchestrator && npm run typecheck -w @compaction-orchestrator/api && npm run typecheck -w @compaction-orchestrator/web",
    "test:sdk": "npm run build -w @anshulluhsna/compaction-orchestrator && node scripts/sdk-smoke-test.mjs",
    "test:cli": "npm run build -w @anshulluhsna/compaction-orchestrator && node scripts/cli-smoke-test.mjs",
    "test:api": "npm run build && node scripts/api-integration-test.mjs",
    "test:accs": "npm run build -w @anshulluhsna/compaction-orchestrator && node scripts/accs-smoke-test.mjs",
    "eval:accs": "npm run build -w @anshulluhsna/compaction-orchestrator && node scripts/evaluate-accs.mjs",
    "eval:deepseek": "npm run build -w @anshulluhsna/compaction-orchestrator && node scripts/deepseek-accs-demo.mjs",
    "test:oneshot": "node scripts/oneshot-compact-test.mjs",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:persistence": "node scripts/persistence-test.mjs",
    "demo:cli": "npm run build -w @anshulluhsna/compaction-orchestrator && node packages/core/dist/cli.js examples/coding-agent-session.json",
    "demo:sdk": "npm run build -w @anshulluhsna/compaction-orchestrator && node examples/customer-support-sdk.mjs",
    "demo:coding": "npm run build -w @anshulluhsna/compaction-orchestrator && node examples/coding-agent-sdk.mjs",
    "demo:voice": "npm run build -w @anshulluhsna/compaction-orchestrator && node examples/voice-agent-sdk.mjs",
    "demo:support": "node scripts/customer-support-e2e.mjs",
    "eval:support": "node scripts/evaluate-customer-support.mjs",
    "openai:check": "node scripts/openai-check.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.9.3"
  }
}
